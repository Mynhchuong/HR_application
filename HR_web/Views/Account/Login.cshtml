@model HR_web.Models.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>HR System | Login</title>

    <link href="https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700" rel="stylesheet" />
    <link href="~/assets/css/material-dashboard.css?v=3.2.0" rel="stylesheet" />

    <style>
        html, body {
            margin: 0; padding: 0; height: 100%;
            font-family: 'Inter', sans-serif;
        }
        body {
            background: url('/assets/img/Login.jpg') no-repeat center center fixed;
            background-size: cover;
        }
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0,0,0,0.35);
            padding: 20px;
        }
        .login-card {
            width: 100%; max-width: 420px;
            background: #fff; border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        .login-header {
            padding: 25px; text-align: center;
            border-bottom: 1px solid #e9ecef;
        }
        .login-header img { width: 149px; height: auto; margin-bottom: 15px; }
        .login-header h4 { margin: 0; font-weight: 600; color: #344767; }
        .login-header p  { margin-top: 5px; font-size: 13px; color: #6c757d; }
        .login-body { padding: 25px; }
        .form-label { font-size: 14px; font-weight: 500; margin-bottom: 6px; }
        .form-control { height: 56px; font-size: 16px; border-radius: 10px; padding: 10px 12px; }
        .password-wrap { position: relative; }
        .password-toggle {
            position: absolute; right: 15px; top: 50%;
            transform: translateY(-50%); cursor: pointer; font-size: 18px;
        }
        .btn-login { height: 56px; font-size: 18px; font-weight: 600; border-radius: 12px; }
        @@media (max-width: 576px) {
            .login-card { max-width: 100%; border-radius: 15px; }
            .login-body  { padding: 20px; }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <!-- HEADER -->
            <div class="login-header">
                <img src="~/assets/img/samho logo.png" alt="Company Logo" />
                <h4>HR System</h4>
                <p>Đăng nhập để tiếp tục</p>
            </div>

            <!-- BODY -->
            <div class="login-body">
                <!-- Dùng TagHelper asp-action thay Html.BeginForm cũ -->
                <form asp-controller="Account" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()

                    <!-- MÃ NV -->
                    <div class="mb-3">
                        <label class="form-label">Mã số nhân viên</label>
                        <input asp-for="EMPCD" class="form-control" placeholder="VD: W001" autocomplete="username" />
                        <span asp-validation-for="EMPCD" class="text-danger small"></span>
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <div class="password-wrap">
                            <input asp-for="Password" type="password" id="passwordInput"
                                   class="form-control" placeholder="Nhập mật khẩu"
                                   autocomplete="current-password" />
                            <span class="password-toggle" onclick="togglePassword()">👁</span>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <!-- REMEMBER ME -->
                    <div class="form-check form-switch d-flex align-items-center mb-3">
                        <input asp-for="RememberMe" class="form-check-input" id="rememberMe" />
                        <label class="form-check-label ms-2" for="rememberMe">Nhớ đăng nhập</label>
                    </div>

                    <!-- Validation Summary (lỗi đăng nhập sai) -->
                    <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                    <!-- BUTTON -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-dark btn-login">Đăng nhập</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            input.type = input.type === "password" ? "text" : "password";
        }
    </script>
</body>
</html>
