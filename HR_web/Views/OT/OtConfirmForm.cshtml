@model HR_web.Models.OT.OTTodayModel
@using HR_web.Helpers

@{
    ViewData["Title"] = "Xác nhận Tăng ca";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --app-primary: #4f46e5;
        --app-bg: #f8fafc;
        --app-card: #ffffff;
    }

    .ot-confirm-container {
        max-width: 600px;
        margin: 0 auto;
        padding-bottom: 5rem;
    }

    /* Stats Card (Week/Month/Year) */
    .stats-card {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        border-radius: 28px;
        padding: 1.5rem;
        color: #fff;
        margin-bottom: 1.5rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        display: flex;
        justify-content: space-around;
        text-align: center;
    }

    .stat-item { flex: 1; }
    .stat-item:not(:last-child) { border-right: 1px solid rgba(255,255,255,0.1); }
    .stat-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; opacity: 0.7; letter-spacing: 0.05em; }
    .stat-value { font-size: 1.25rem; font-weight: 800; margin-top: 0.25rem; }

    /* Main Ticket Card */
    .ticket-card {
        background: #fff;
        border-radius: 32px;
        padding: 2rem 1.5rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
        position: relative;
    }

    .ticket-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .ticket-title {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--app-primary);
        letter-spacing: 0.1em;
        margin-bottom: 0.5rem;
        display: block;
    }

    .ticket-date {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1e293b;
    }

    .hours-display {
        background: #f8fafc;
        border-radius: 24px;
        padding: 1.5rem;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .hours-label { font-size: 0.85rem; font-weight: 700; color: #64748b; margin-bottom: 0.25rem; }
    .hours-value { font-size: 3rem; font-weight: 900; color: #1e293b; line-height: 1; }
    .hours-unit { font-size: 1.25rem; color: #94a3b8; font-weight: 600; margin-left: 4px; }

    .info-list {
        margin-bottom: 2rem;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 1rem 0;
        border-bottom: 1px dashed #f1f5f9;
    }

    .info-label { color: #64748b; font-weight: 500; font-size: 0.95rem; }
    .info-value { color: #1e293b; font-weight: 700; font-size: 0.95rem; }

    .status-badge {
        padding: 0.5rem 1rem;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    /* Action Buttons - Large and Touch Friendly */
    .action-group {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn-action {
        height: 64px;
        border-radius: 20px;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        border: none;
        transition: all 0.2s ease;
    }

    .btn-approve { background: #10b981; color: #fff; box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2); }
    .btn-reject { background: #fff; color: #ef4444; border: 2px solid #fee2e2; }

    .btn-action:active { transform: scale(0.96); }

    .note-box {
        background: #fffbef;
        border-radius: 20px;
        padding: 1.25rem;
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        border: 1px solid #fef3c7;
    }

    .note-icon { width: 48px; flex-shrink: 0; }
    .note-text { font-size: 0.85rem; color: #92400e; line-height: 1.5; font-style: italic; }

    @@media (max-width: 480px) {
        .hours-value { font-size: 2.5rem; }
    }
</style>

<div class="ot-confirm-container py-3">
    @if (Model == null)
    {
        <div class="text-center py-5">
            <span class="material-symbols-rounded text-warning" style="font-size: 4rem;">event_busy</span>
            <h4 class="mt-3 fw-bold">Không có dữ liệu</h4>
            <p class="text-muted">Hôm nay không có lịch tăng ca nào cần xác nhận.</p>
        </div>
    }
    else
    {
        <!-- Cumulative Stats -->
        <div class="stats-card">
            <div class="stat-item">
                <div class="stat-label">Tuần</div>
                <div class="stat-value">@Model.SUM_WEEK</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Tháng</div>
                <div class="stat-value">@Model.SUM_MONTH</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Năm</div>
                <div class="stat-value">@Model.SUM_YEAR</div>
            </div>
        </div>

        <!-- Ticket -->
        <div class="ticket-card">
            <div class="ticket-header">
                <span class="ticket-title">Phiếu xác nhận tăng ca</span>
                <div class="ticket-date">@(Model.WORK_DATE.HasValue ? Model.WORK_DATE.Value.ToString("dd/MM/yyyy") : "-")</div>
            </div>

            <div class="hours-display">
                <div class="hours-label">Tổng số giờ</div>
                <div class="hours-value">@Model.OT_HOURS<span class="hours-unit">giờ</span></div>
            </div>

            <div class="info-list">
                <div class="info-row">
                    <span class="info-label">Mã số thẻ</span>
                    <span class="info-value">@Model.EMPCD</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Khung giờ</span>
                    <span class="info-value">
                        @(Model.START_OT.HasValue ? Model.START_OT.Value.ToString("HH:mm") : "--:--") - 
                        @(Model.END_OT.HasValue ? Model.END_OT.Value.ToString("HH:mm") : "--:--")
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Thời gian nghỉ</span>
                    <span class="info-value">@(string.IsNullOrEmpty(Model.OT_REST) ? "0" : Model.OT_REST)</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Trạng thái</span>
                    <span class="info-value">
                        @{
                            string statusClass = "bg-light text-muted";
                            string statusText = "Chưa rõ";
                            if (Model.CONFIRM_STATUS == "PENDING") { statusClass = "bg-warning-subtle text-warning-emphasis"; statusText = "Chờ xác nhận"; }
                            else if (Model.CONFIRM_STATUS == "CONFIRMED") { statusClass = "bg-success-subtle text-success-emphasis"; statusText = "Đã chấp nhận"; }
                            else if (Model.CONFIRM_STATUS == "REJECTED") { statusClass = "bg-danger-subtle text-danger-emphasis"; statusText = "Đã từ chối"; }
                        }
                        <span class="status-badge @statusClass">@statusText</span>
                    </span>
                </div>
            </div>

            @if (Model.CONFIRM_STATUS == "PENDING")
            {
                <div class="note-box">
                    <img src="~/assets/img/illustrations/chi.png" class="note-icon" alt="Note" />
                    <div class="note-text">
                        "Việc làm tăng ca là hoàn toàn <strong>tự nguyện</strong>. Nếu không đồng ý, bạn có thể ra về sau giờ làm việc bình thường."
                    </div>
                </div>

                <form asp-controller="OT" asp-action="OtConfirmForm" method="post" id="frmOtConfirm">
                    <input type="hidden" name="empcd" value="@Model.EMPCD" />
                    <input type="hidden" name="confirmStatus" id="confirmStatus" value="" />

                    <div class="action-group">
                        <button type="button" class="btn-action btn-approve" onclick="submitConfirm('CONFIRMED')">
                            <span class="material-symbols-rounded">check_circle</span>
                            CHẤP NHẬN TĂNG CA
                        </button>
                        <button type="button" class="btn-action btn-reject" onclick="submitConfirm('REJECTED')">
                            <span class="material-symbols-rounded">cancel</span>
                            KHÔNG ĐỒNG Ý
                        </button>
                    </div>
                </form>
            }
            
            @if (Model.CONFIRM_STATUS == "REJECTED" && !string.IsNullOrEmpty(Model.REJECT_REASON))
            {
                <div class="alert alert-danger mt-3 rounded-4">
                    <strong>Lý do từ chối:</strong> @Model.REJECT_REASON
                </div>
            }
        </div>
    }
</div>

<script>
    function submitConfirm(status) {
        const msg = status === 'CONFIRMED' ? 'Bạn chắc chắn CHẤP NHẬN tăng ca?' : 'Bạn chắc chắn KHÔNG ĐỒNG Ý tăng ca?';
        if (confirm(msg)) {
            document.getElementById('confirmStatus').value = status;
            document.getElementById('frmOtConfirm').submit();
        }
    }
</script>
