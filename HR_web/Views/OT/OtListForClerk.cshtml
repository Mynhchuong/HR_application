@using HR_web.Models.OT
@model List<OTClerkModel>

@{
    ViewData["Title"] = "Theo dõi Xác Nhận Tăng Ca";
    var summary = ViewBag.Summary as OTClerkSummary;
    var workDate = ViewBag.WorkDate as string;
    // Thay Request.QueryString["clerk_empcd"] → Context.Request.Query["clerk_empcd"]
    var clerkEmpcd = Context.Request.Query["clerk_empcd"].ToString();
}

@section Styles {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <style>
        .dataTables_filter { display: flex; align-items: center; justify-content: flex-end; gap: 10px; }
        .dataTables_filter input { margin-left: 0 !important; }
        .dataTables_wrapper .row { margin-bottom: 0.5rem; }
        .stats-card .icon { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px; }
    </style>
}

<div class="container-fluid py-4">
    <!-- Thống kê -->
    <div class="row mb-4">
        <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4">
            <div class="card stats-card">
                <div class="card-body p-3">
                    <div class="row">
                        <div class="col-8"><div class="numbers"><p class="text-sm mb-0 text-uppercase font-weight-bold text-secondary">Tổng Cần Ký</p><h5 class="font-weight-bolder mb-0">@(summary?.TOTAL ?? 0)</h5></div></div>
                        <div class="col-4 text-end"><div class="icon bg-gradient-info text-white shadow-info ms-auto"><i class="bi bi-people-fill fs-4"></i></div></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4">
            <div class="card stats-card">
                <div class="card-body p-3">
                    <div class="row">
                        <div class="col-8"><div class="numbers"><p class="text-sm mb-0 text-uppercase font-weight-bold text-warning">Đang Chờ</p><h5 class="font-weight-bolder mb-0">@(summary?.PENDING ?? 0)</h5></div></div>
                        <div class="col-4 text-end"><div class="icon bg-gradient-warning text-white shadow-warning ms-auto"><i class="bi bi-hourglass-split fs-4"></i></div></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4">
            <div class="card stats-card">
                <div class="card-body p-3">
                    <div class="row">
                        <div class="col-8"><div class="numbers"><p class="text-sm mb-0 text-uppercase font-weight-bold text-success">Đã Ký Đồng Ý</p><h5 class="font-weight-bolder mb-0">@(summary?.CONFIRMED ?? 0)</h5></div></div>
                        <div class="col-4 text-end"><div class="icon bg-gradient-success text-white shadow-success ms-auto"><i class="bi bi-check-circle-fill fs-4"></i></div></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4">
            <div class="card stats-card">
                <div class="card-body p-3">
                    <div class="row">
                        <div class="col-8"><div class="numbers"><p class="text-sm mb-0 text-uppercase font-weight-bold text-danger">Từ Chối</p><h5 class="font-weight-bolder mb-0">@(summary?.REJECTED ?? 0)</h5></div></div>
                        <div class="col-4 text-end"><div class="icon bg-gradient-danger text-white shadow-danger ms-auto"><i class="bi bi-x-circle-fill fs-4"></i></div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bảng Dữ Liệu -->
    <div class="card my-4 mb-4">
        <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
            <div class="bg-gradient-primary shadow-primary border-radius-lg pt-3 pb-2 px-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h6 class="text-white text-capitalize mb-0"><i class="fas fa-users me-1"></i> Danh Sách Thành Viên Bộ Phận</h6>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <button class="btn btn-sm btn-outline-white mb-0" id="exportExcelBtn" style="background-color: #217346; color: white; border: none;">
                        <i class="bi bi-file-earmark-excel me-1 fs-6"></i> Xuất Excel
                    </button>
                    <form method="get" action="@Url.Action("OtListForClerk", "OT")" class="d-flex align-items-center m-0">
                        @if (!string.IsNullOrEmpty(clerkEmpcd))
                        {
                            <input type="hidden" name="clerk_empcd" value="@clerkEmpcd" />
                        }
                        <div class="input-group input-group-sm bg-white border-radius-md px-2 py-1 align-items-center shadow-sm" style="min-height: 36px;">
                            <label class="mb-0 text-dark fw-bold me-2"><i class="bi bi-calendar3 text-primary"></i> Ngày:</label>
                            <input type="date" name="work_date" class="form-control form-control-sm border-0 bg-transparent text-dark p-0"
                                   style="width: 120px; outline: none !important; box-shadow: none !important;"
                                   value="@workDate" onchange="this.form.submit()" />
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="card-body px-0 pt-0 pb-2 mt-3">
            <div class="table-responsive p-0 px-4">
                <table class="table align-items-center mb-0 w-100 table-hover table-striped" id="otTable">
                    <thead class="bg-light">
                        <tr>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Mã NV</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Họ &amp; Tên</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Bộ Phận (Dept)</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Chuyền (Line)</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Nhóm Việc</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 text-center">Tăng ca</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 text-center">Giờ TC</th>
                            <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-9">Tình Trạng Ký</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-2 text-sm">@item.EMPCD</td>
                                    <td class="px-2 text-sm fw-bold text-dark">@item.EMP_NAME</td>
                                    <td class="px-2 text-sm">@item.DEPT_NAME</td>
                                    <td class="px-2 text-sm">@item.LINE_NAME</td>
                                    <td class="px-2 text-sm">@item.WORK_NAME</td>
                                    <td class="px-2 text-sm text-center">
                                        <span class="badge border border-info text-info fw-normal">@item.OT_TYPE: @(item.OT_HOURS)h</span>
                                    </td>
                                    <td class="px-2 text-sm text-center">
                                        @if (item.START_OT.HasValue && item.END_OT.HasValue)
                                        {
                                            <span class="badge border border-secondary text-secondary fw-normal">
                                                <i class="bi bi-clock me-1"></i>@item.START_OT.Value.ToString("HH:mm") - @item.END_OT.Value.ToString("HH:mm")
                                            </span>
                                        }
                                        else if (item.START_OT.HasValue)
                                        {
                                            <span class="badge border border-secondary text-secondary fw-normal">
                                                <i class="bi bi-clock me-1"></i>@item.START_OT.Value.ToString("HH:mm")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted text-xs">-</span>
                                        }
                                    </td>
                                    <td class="align-middle text-center text-sm">
                                        @if (item.CONFIRM_STATUS == "CONFIRMED")
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Chấp nhận</span>
                                            if (item.CONFIRM_DATE.HasValue)
                                            {
                                                <div class="text-xs text-muted mt-1">@item.CONFIRM_DATE.Value.ToString("HH:mm dd/MM")</div>
                                            }
                                        }
                                        else if (item.CONFIRM_STATUS == "REJECTED")
                                        {
                                            <span class="badge bg-danger" data-bs-toggle="tooltip" title="@item.REJECT_REASON">Từ chối</span>
                                            if (item.CONFIRM_DATE.HasValue)
                                            {
                                                <div class="text-xs text-muted mt-1">@item.CONFIRM_DATE.Value.ToString("HH:mm dd/MM")</div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i> Chờ ký</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            var table = $('#otTable').DataTable({
                language: { url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" },
                pageLength: 25,
                ordering: true,
                responsive: true,
                initComplete: function () {
                    this.api().columns([2, 3]).every(function () {
                        var column = this;
                        var headerName = $(column.header()).text().split(' ')[0];
                        if (headerName === "Bộ") headerName = "Bộ Phận";
                        var select = $('<select class="form-select border border-secondary form-select-sm d-inline-block w-auto mx-1"><option value="">' + headerName + ' (Tất cả)</option></select>')
                            .prependTo($('.dataTables_filter'))
                            .on('change', function () {
                                var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                column.search(val ? '^' + val + '$' : '', true, false).draw();
                            });
                        column.data().unique().sort().each(function (d) {
                            if (d && d.trim() !== '') select.append('<option value="' + d + '">' + d + '</option>');
                        });
                    });
                }
            });

            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (el) { return new bootstrap.Tooltip(el); });

            // Use Newtonsoft to serialize Model for JS
            $('#exportExcelBtn').on('click', function () {
                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Đang xử lý...');
                try {
                    const rawData = @Html.Raw(JsonConvert.SerializeObject(Model ?? new List<OTClerkModel>()));
                    if (!rawData || rawData.length === 0) { alert('Không có dữ liệu để xuất!'); return; }

                    const headers = ['STT','Mã NV','Họ Tên','Bộ Phận','Chuyền','Nhóm Việc','Loại TC','Giờ TC','Giờ Bắt Đầu','Giờ Kết Thúc','Tình Trạng','Ngày Ký'];
                    let html = '<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">';
                    html += '<head><meta charset="utf-8" /></head><body>';
                    html += '<table border="1"><thead><tr>';
                    headers.forEach(function (h) { html += `<th style="background-color: #d9ead3; font-weight: bold;">${h}</th>`; });
                    html += '</tr></thead><tbody>';

                    function formatTime(s) { if (!s) return ''; const d = new Date(s); if (isNaN(d)) return ''; return ('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2); }
                    function formatDateTime(s) { if (!s) return ''; const d = new Date(s); if (isNaN(d)) return ''; return ('0'+d.getDate()).slice(-2)+'/'+('0'+(d.getMonth()+1)).slice(-2)+'/'+d.getFullYear()+' '+('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2)+':'+('0'+d.getSeconds()).slice(-2); }
                    function escHtml(u) { return (u||'').replace(/[&<"'>]/g, function(m) { return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m]||m; }); }

                    rawData.forEach(function (r, i) {
                        const s = r.CONFIRM_STATUS === 'CONFIRMED' ? 'Chấp nhận' : (r.CONFIRM_STATUS === 'REJECTED' ? 'Từ chối' : 'Chờ ký');
                        const otType = r.OT_AFTER === 'Y' ? 'Sau giờ' : (r.OT_BEFORE === 'Y' ? 'Trước giờ' : '');
                        html += '<tr>';
                        html += `<td style="text-align:center;">${i+1}</td>`;
                        html += `<td style="mso-number-format:'@@';">${escHtml(r.EMPCD||'')}</td>`;
                        html += `<td style="mso-number-format:'@@';">${escHtml(r.EMP_NAME||'')}</td>`;
                        html += `<td>${escHtml(r.DEPT_NAME||'')}</td>`;
                        html += `<td>${escHtml(r.LINE_NAME||'')}</td>`;
                        html += `<td>${escHtml(r.WORK_NAME||'')}</td>`;
                        html += `<td>${otType}</td>`;
                        html += `<td style="text-align:center;">${r.OT_HOURS||0}</td>`;
                        html += `<td style="text-align:center;">${r.START_OT ? formatTime(r.START_OT) : ''}</td>`;
                        html += `<td style="text-align:center;">${r.END_OT ? formatTime(r.END_OT) : ''}</td>`;
                        html += `<td>${s}</td>`;
                        html += `<td>${r.CONFIRM_DATE ? formatDateTime(r.CONFIRM_DATE) : ''}</td>`;
                        html += '</tr>';
                    });
                    html += '</tbody></table></body></html>';
                    const blob = new Blob([html], { type: 'application/vnd.ms-excel;charset=utf-8;' });
                    const link = document.createElement('a');
                    link.href = URL.createObjectURL(blob);
                    link.download = 'OT_Clerk_Export_' + '@workDate' + '.xls';
                    link.click();
                } catch (err) {
                    alert('Lỗi xuất Excel: ' + err.message);
                } finally {
                    btn.prop('disabled', false).html('<i class="bi bi-file-earmark-excel me-1 fs-6"></i> Xuất Excel');
                }
            });
        });
    </script>
}
