@{
    ViewData["Title"] = "Theo dõi Xác Nhận Tăng Ca";
    var workDate = ViewBag.WorkDate as string;
}

@section Styles {
    <style>
        .stats-card .icon { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px; }
        #otTableBody tr td { vertical-align: middle; }
        .filter-bar select { min-width: 160px; }
        #paginationInfo { font-size: .82rem; color: #6c757d; }
        .emp-name { font-family: 'Times New Roman', serif; font-weight: 600; }
        @@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
        .pagination .page-link { cursor: pointer; }
        .pagination .page-item.disabled .page-link { cursor: default; }
    </style>
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4">
            <div class="card stats-card"><div class="card-body p-3"><div class="row"><div class="col-8"><p class="text-sm mb-0 text-uppercase font-weight-bold text-secondary">Tổng Cần Ký</p><h5 class="font-weight-bolder mb-0" id="summaryTotal">-</h5></div><div class="col-4 text-end"><div class="icon bg-gradient-info text-white shadow-info ms-auto"><i class="bi bi-people-fill fs-4"></i></div></div></div></div></div>
        </div>
        <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4">
            <div class="card stats-card"><div class="card-body p-3"><div class="row"><div class="col-8"><p class="text-sm mb-0 text-uppercase font-weight-bold text-warning">Đang Chờ</p><h5 class="font-weight-bolder mb-0" id="summaryPending">-</h5></div><div class="col-4 text-end"><div class="icon bg-gradient-warning text-white shadow-warning ms-auto"><i class="bi bi-hourglass-split fs-4"></i></div></div></div></div></div>
        </div>
        <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4">
            <div class="card stats-card"><div class="card-body p-3"><div class="row"><div class="col-8"><p class="text-sm mb-0 text-uppercase font-weight-bold text-success">Đã Ký Đồng Ý</p><h5 class="font-weight-bolder mb-0" id="summaryConfirmed">-</h5></div><div class="col-4 text-end"><div class="icon bg-gradient-success text-white shadow-success ms-auto"><i class="bi bi-check-circle-fill fs-4"></i></div></div></div></div></div>
        </div>
        <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4">
            <div class="card stats-card"><div class="card-body p-3"><div class="row"><div class="col-8"><p class="text-sm mb-0 text-uppercase font-weight-bold text-danger">Từ Chối</p><h5 class="font-weight-bolder mb-0" id="summaryRejected">-</h5></div><div class="col-4 text-end"><div class="icon bg-gradient-danger text-white shadow-danger ms-auto"><i class="bi bi-x-circle-fill fs-4"></i></div></div></div></div></div>
        </div>
    </div>

    <div class="card my-4 mb-4">
        <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
            <div class="bg-gradient-primary shadow-primary border-radius-lg pt-3 pb-2 px-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h6 class="text-white text-capitalize mb-0"><i class="fas fa-users me-1"></i> Danh Sách Thành Viên Bộ Phận</h6>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <button type="button" id="exportExcelBtn" class="btn btn-sm btn-success mb-0 text-nowrap d-flex align-items-center" style="height:36px;">
                        <i class="bi bi-file-earmark-excel me-1 fs-6"></i> Xuất Excel
                    </button>
                    <form method="get" action="@Url.Action("OtListForClerk", "OT")" class="d-flex align-items-center m-0">
                        <div class="input-group input-group-sm bg-white border-radius-md px-2 py-1 align-items-center shadow-sm" style="min-height:36px;height:36px;">
                            <label class="mb-0 text-dark fw-bold me-2 text-nowrap"><i class="bi bi-calendar3 text-primary me-1"></i> Ngày:</label>
                            <input type="date" name="work_date" class="form-control form-control-sm border-0 bg-transparent text-dark p-0"
                                   style="width:120px;outline:none!important;box-shadow:none!important;"
                                   value="@workDate" onchange="this.form.submit()" />
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @await Html.PartialAsync("_OTFilterBar", new HR_web.Models.OT.OTFilterBarModel
        {
            DeptUrl = Url.Action("GetDeptByScope", "Dropdown")!,
            LineUrl = Url.Action("GetLineByScope", "Dropdown")!,
            WorkUrl = Url.Action("GetWorkByScope", "Dropdown")!
        })

        <div class="card-body px-0 pt-0 pb-2 mt-1">
            <div class="table-responsive p-0 px-4">
                <table class="table align-items-center mb-0 w-100 table-hover table-striped">
                    <thead class="bg-light">
                        <tr>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">#</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Mã NV</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Họ &amp; Tên</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Bộ Phận</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Chuyền</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 px-2">Nhóm Việc</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 text-center">Tăng Ca</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-9 text-center">Giờ TC</th>
                            <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-9">Tình Trạng</th>
                        </tr>
                    </thead>
                    <tbody id="otTableBody"></tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center px-4 mt-3 mb-2">
                <div id="paginationCount" class="text-sm text-secondary"></div>
                <nav><ul class="pagination pagination-sm mb-0" id="paginationBar"></ul></nav>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    const WORK_DATE = '@workDate';
    const PAGE_URL  = '@Url.Action("GetOTClerkDetailPage", "OT")';

    let currentPage = 1, totalPages = 1, totalRecords = 0, isLoading = false, pageSize = 100;

    function buildRow(item, idx) {
        const otType = item.OT_AFTER === 'Y' ? 'Sau' : (item.OT_BEFORE === 'Y' ? 'Trước' : '');
        let timeHtml = '<span class="text-muted text-xs">-</span>';
        if (item.START_OT && item.END_OT)
            timeHtml = `<span class="badge border border-secondary text-secondary fw-normal"><i class="bi bi-clock me-1"></i>${formatTime(item.START_OT)} - ${formatTime(item.END_OT)}</span>`;
        else if (item.START_OT)
            timeHtml = `<span class="badge border border-secondary text-secondary fw-normal"><i class="bi bi-clock me-1"></i>${formatTime(item.START_OT)}</span>`;

        let statusHtml = `<span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Chờ ký</span>`;
        if (item.CONFIRM_STATUS === 'CONFIRMED')
            statusHtml = `<span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Chấp nhận</span>${item.CONFIRM_DATE ? `<div class="text-xs text-muted mt-1">${formatDateTime(item.CONFIRM_DATE)}</div>` : ''}`;
        else if (item.CONFIRM_STATUS === 'REJECTED')
            statusHtml = `<span class="badge bg-danger">Từ chối</span>${item.CONFIRM_DATE ? `<div class="text-xs text-muted mt-1">${formatDateTime(item.CONFIRM_DATE)}</div>` : ''}`;

        return `<tr>
            <td class="px-2 text-xs text-secondary">${idx}</td>
            <td class="px-2 text-sm">${escHtml(item.EMPCD||'')}</td>
            <td class="px-2 text-sm emp-name vni-font" style="text-transform:uppercase;">${escHtml(item.EMP_NAME||'')}</td>
            <td class="px-2 text-sm">${escHtml(item.DEPT_NAME||'')}</td>
            <td class="px-2 text-sm">${escHtml(item.LINE_NAME||'')}</td>
            <td class="px-2 text-sm">${escHtml(item.WORK_NAME||'')}</td>
            <td class="px-2 text-sm text-center"><span class="badge border border-info text-info fw-normal">${otType}: ${item.OT_HOURS||0}h</span></td>
            <td class="px-2 text-sm text-center">${timeHtml}</td>
            <td class="align-middle text-center text-sm">${statusHtml}</td>
        </tr>`;
    }

    function loadData(page = 1) {
        if (isLoading) return;
        isLoading = true; currentPage = page;
        const search = $('#searchInput').val(),
              status = $('#filterStatus').val(),
              deptId = $('#filterDept').val(),
              lineId = $('#filterLine').val(),
              workId = $('#filterWork').val();
        $('#otTableBody').html(`<tr><td colspan="9" class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2 text-sm text-secondary">Đang tải dữ liệu...</div></td></tr>`);
        $.ajax({
            url: PAGE_URL, type: 'GET',
            data: { work_date: WORK_DATE, status, search, dept_id: deptId, line_id: lineId, work_id: workId, page, page_size: pageSize },
            success: function(res) {
                const isSuccess = res.success || res.Success;
                if (!isSuccess) {
                    $('#otTableBody').html(`<tr><td colspan="9" class="text-center text-danger py-4">Lỗi: ${res.message || res.Message || 'Dữ liệu không hợp lệ'}</td></tr>`);
                    return;
                }
                const summary = res.summary || res.Summary;
                if (summary) {
                    $('#summaryTotal').text((summary.TOTAL || summary.Total || 0).toLocaleString());
                    $('#summaryPending').text((summary.PENDING || summary.Pending || 0).toLocaleString());
                    $('#summaryConfirmed').text((summary.CONFIRMED || summary.Confirmed || 0).toLocaleString());
                    $('#summaryRejected').text((summary.REJECTED || summary.Rejected || 0).toLocaleString());
                }
                totalRecords = res.total || res.Total || 0;
                totalPages   = res.total_pages || res.TotalPages || 0;
                const data   = res.data || res.Data || [];
                const msg    = res.message || res.Message || '';
                if (!data.length) {
                    const hint = msg ? `<div class="text-xs text-warning mt-1"><i class="bi bi-exclamation-triangle me-1"></i>${msg}</div>` : '';
                    $('#otTableBody').html(`<tr><td colspan="9" class="text-center text-muted py-4">Không có dữ liệu${hint}</td></tr>`);
                } else {
                    $('#otTableBody').html(data.map((item, i) => buildRow(item, (page-1)*pageSize+i+1)).join(''));
                }
                renderPagination();
            },
            error: function(xhr) {
                $('#otTableBody').html(`<tr><td colspan="9" class="text-center text-danger py-4">Lỗi kết nối (${xhr.status}): ${xhr.statusText}</td></tr>`);
            },
            complete: function() { isLoading = false; }
        });
    }

    function renderPagination() {
        if (totalRecords === 0) {
            $('#paginationInfo').html(`<strong>0</strong> trong <strong>0</strong>`);
            $('#paginationCount').html(`Trang <strong>0</strong> / 0`);
            $('#paginationBar').empty();
            return;
        }
        const start = (currentPage-1)*pageSize+1, end = Math.min(currentPage*pageSize, totalRecords);
        $('#paginationInfo').html(`<strong>${start.toLocaleString()} - ${end.toLocaleString()}</strong> trong <strong>${totalRecords.toLocaleString()}</strong>`);
        $('#paginationCount').html(`Trang <strong>${currentPage}</strong> / ${totalPages}`);
        const $bar = $('#paginationBar').empty();
        const mkBtn = (label, p, disabled, active) => {
            const li = $('<li class="page-item">').toggleClass('disabled',!!disabled).toggleClass('active',!!active);
            $('<a class="page-link">').html(label).on('click', () => { if(!disabled&&!active) loadData(p); }).appendTo(li);
            return li;
        };
        $bar.append(mkBtn('&laquo;',1,currentPage<=1)).append(mkBtn('&lsaquo;',currentPage-1,currentPage<=1));
        let from=Math.max(1,currentPage-2), to=Math.min(totalPages,currentPage+2);
        if(from>1) $bar.append(mkBtn('1',1)).append('<li class="page-item disabled"><a class="page-link">…</a></li>');
        for(let p=from;p<=to;p++) $bar.append(mkBtn(p,p,false,p===currentPage));
        if(to<totalPages) $bar.append('<li class="page-item disabled"><a class="page-link">…</a></li>').append(mkBtn(totalPages,totalPages));
        $bar.append(mkBtn('&rsaquo;',currentPage+1,currentPage>=totalPages)).append(mkBtn('&raquo;',totalPages,currentPage>=totalPages));
    }

    $('#pageSizeSelect').on('change', function() { pageSize=parseInt($(this).val()); loadData(1); });
    $('#filterStatus, #filterDept, #filterLine, #filterWork').on('change', () => loadData(1));
    $('#searchInput').on('input', debounce(() => loadData(1), 400));

    $('#exportExcelBtn').on('click', async function() {
        const $btn=$(this), originalHtml=$btn.html();
        $btn.prop('disabled',true).html('<span class="spinner-border spinner-border-sm me-1"></span> Đang nén...');
        try {
            const statusVal = encodeURIComponent($('#filterStatus').val() || '');
            const searchVal = encodeURIComponent($('#searchInput').val() || '');
            const deptId    = encodeURIComponent($('#filterDept').val() || '');
            const lineId    = encodeURIComponent($('#filterLine').val() || '');
            const workId    = encodeURIComponent($('#filterWork').val() || '');
            let exportRows=[], pg=1, pgTotal=1;
            do {
                const res = await $.getJSON(`${PAGE_URL}?work_date=${WORK_DATE}&status=${statusVal}&search=${searchVal}&dept_id=${deptId}&line_id=${lineId}&work_id=${workId}&page=${pg}&page_size=1000`);
                if(!res||!res.success) break;
                pgTotal=res.total_pages; exportRows=exportRows.concat(res.data||[]);
                $btn.html(`<span class="spinner-border spinner-border-sm me-1"></span> ${exportRows.length.toLocaleString()}…`);
                pg++;
            } while(pg<=pgTotal);
            if(!exportRows.length){alert('Không có dữ liệu để xuất');return;}
            const headers=['STT','Mã NV','Họ Tên','Bộ Phận','Chuyền','Nhóm Việc','Loại TC','Giờ TC','Giờ Bắt Đầu','Giờ Kết Thúc','Tình Trạng','Ngày Ký'];
            let html='<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><meta charset="utf-8" /></head><body>';
            html+='<table border="1"><thead><tr>'+headers.map(h=>`<th style="background:#d9ead3;font-weight:bold">${h}</th>`).join('')+'</tr></thead><tbody>';
            exportRows.forEach((r,i)=>{
                const s=r.CONFIRM_STATUS==='CONFIRMED'?'Chấp nhận':(r.CONFIRM_STATUS==='REJECTED'?'Từ chối':'Chờ ký');
                const otType=r.OT_AFTER==='Y'?'Sau giờ':(r.OT_BEFORE==='Y'?'Trước giờ':'');
                html+=`<tr><td style="text-align:center">${i+1}</td><td style="mso-number-format:'@@'">${escHtml(r.EMPCD||'')}</td><td style="mso-number-format:'@@'">${escHtml(r.EMP_NAME||'')}</td><td>${escHtml(r.DEPT_NAME||'')}</td><td>${escHtml(r.LINE_NAME||'')}</td><td>${escHtml(r.WORK_NAME||'')}</td><td>${otType}</td><td style="text-align:center">${r.OT_HOURS||0}</td><td style="text-align:center">${r.START_OT?formatTime(r.START_OT):''}</td><td style="text-align:center">${r.END_OT?formatTime(r.END_OT):''}</td><td>${s}</td><td>${r.CONFIRM_DATE?formatDateTime(r.CONFIRM_DATE):''}</td></tr>`;
            });
            html+='</tbody></table></body></html>';
            const blob=new Blob([html],{type:'application/vnd.ms-excel;charset=utf-8;'});
            const link=document.createElement('a'); link.href=URL.createObjectURL(blob); link.download=`OT_Clerk_Export_${WORK_DATE}.xls`; link.click();
        } catch(err){alert('Lỗi xuất file: '+err.message);}
        finally{$btn.prop('disabled',false).html(originalHtml);}
    });

    function formatTime(s){const d=new Date(s);if(isNaN(d))return'';return('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2);}
    function formatDateTime(s){const d=new Date(s);if(isNaN(d))return'';return('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2)+' '+('0'+d.getDate()).slice(-2)+'/'+('0'+(d.getMonth()+1)).slice(-2);}
    function escHtml(str){return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
    function debounce(fn,d){let t;return function(){clearTimeout(t);t=setTimeout(fn,d);};}

    $(document).ready(function() {
        if (typeof Select2Helper !== 'undefined') Select2Helper.init();
        loadData(1);
    });
    </script>
}
