@{
    ViewData["Title"] = "Quản lý Phiếu lương (HR)";
}

<div class="container-fluid py-4">
    <div class="row">
        <!-- 1. Chọn Kỳ lương & Thao tác nhanh -->
        <div class="col-12 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-3">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Chọn kỳ lương <span class="text-danger">*</span></label>
                            <select id="selectPeriod" class="form-select border ps-2">
                                <option value="">-- Chọn tháng/năm --</option>
                                @foreach (var p in ViewBag.Periods)
                                {
                                    <option value="@p.ID.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                            data-published="@p.IS_PUBLISHED">
                                        @p.PERIOD_NAME @(p.IS_PUBLISHED == 1 ? "(Đã công bố)" : "(Nháp)")
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-8 text-end pt-4">
                            <button class="btn btn-outline-primary mb-0" data-bs-toggle="modal" data-bs-target="#modalNewPeriod">
                                <i class="fas fa-plus me-1"></i> Kỳ mới
                            </button>
                            <button id="btnConfigColumns" class="btn btn-outline-info mb-0 ms-2" disabled>
                                <i class="fas fa-cog me-1"></i> Cấu hình cột
                            </button>
                            <button id="btnUploadExcel" class="btn btn-outline-dark mb-0 ms-2" disabled title="Tải dữ liệu từ Excel lên hệ thống">
                                <i class="fas fa-upload me-1"></i> Upload
                            </button>
                            <button id="btnExportExcel" class="btn btn-outline-success mb-0 ms-2" disabled title="Tải toàn bộ dữ liệu của kỳ này về máy">
                                <i class="fas fa-file-excel me-1"></i> Xuất Excel
                            </button>
                            <button id="btnRelease" class="btn btn-primary mb-0 ms-2" disabled>
                                <i class="fas fa-paper-plane me-1"></i> Công bố
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Danh sách dữ liệu (Preview) -->
        <div class="col-12" id="divDataPreview" style="display:none;">
            <div class="card shadow-sm border-0">
                <div class="card-header pb-0 bg-white border-0">
                    <div class="row">
                        <div class="col-6">
                            <h6 class="mb-0">Dữ liệu phiếu lương <span id="spanTotalRecords" class="badge bg-secondary">0</span></h6>
                        </div>
                        <div class="col-6 text-end">
                            <div class="input-group input-group-sm w-75 ms-auto border rounded ps-2">
                                <span class="input-group-text border-0 bg-transparent ps-0"><i class="fas fa-search text-secondary"></i></span>
                                <input type="text" id="txtSearchEmp" class="form-control border-0" placeholder="Tìm mã thẻ hoặc tên nhân viên...">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body px-0 pt-0 pb-2">
                    <div class="table-responsive p-0" style="max-height: 500px;">
                        <table class="table align-items-center mb-0" id="tablePayslipAdmin">
                            <thead class="bg-gray-100 position-sticky top-0" style="z-index: 10;">
                                <tr>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Nhân viên</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyAdminData"></tbody>
                        </table>
                    </div>
                    <div class="p-3 d-flex justify-content-between align-items-center border-top">
                        <div id="divPnlInfo" class="text-sm text-secondary"></div>
                        <nav><ul class="pagination pagination-sm mb-0" id="ulPagination"></ul></nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Tạo kỳ lương mới -->
<div class="modal fade" id="modalNewPeriod" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Tạo kỳ lương mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên kỳ lương (VD: Lương Tháng 03/2026)</label>
                    <input type="text" id="txtPeriodName" class="form-control border ps-2" placeholder="Nhập tên kỳ lương...">
                </div>
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label fw-bold">Từ ngày</label>
                        <input type="date" id="txtDateFrom" class="form-control border ps-2">
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold">Đến ngày</label>
                        <input type="date" id="txtDateTo" class="form-control border ps-2">
                    </div>
                </div>
                <div class="mb-3">
                    <div class="form-check form-switch pb-2">
                        <input class="form-check-input" type="checkbox" id="chkAutoPublish">
                        <label class="form-check-label fw-bold" for="chkAutoPublish">Hẹn giờ tự động công bố</label>
                    </div>
                    <div id="divPublishTime" style="display:none;">
                        <label class="form-label fw-bold text-primary">Thời gian tự động mở (Ngày &amp; Giờ)</label>
                        <input type="datetime-local" id="txtPublishDate" class="form-control border ps-2">
                        <small class="text-muted">Đúng thời điểm này nhân viên sẽ tự thấy phiếu lương.</small>
                    </div>
                </div>
                <div class="mb-0">
                    <label class="form-label fw-bold">Ghi chú / Thông báo (Hiện trên phiếu lương)</label>
                    <textarea id="txtRemark" class="form-control border ps-2" rows="3" placeholder="Ví dụ: Chúc mừng năm mới..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary mb-0" data-bs-dismiss="modal">Hủy</button>
                <button id="btnCreatePeriodSave" class="btn btn-primary mb-0">Lưu lại</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Cấu hình cột -->
<div class="modal fade" id="modalConfigColumns" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">Cấu hình hiển thị cột cho kỳ này</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <table class="table align-items-center mb-0">
                    <thead class="bg-gray-100 position-sticky top-0">
                        <tr>
                            <th class="ps-4">Thứ tự</th><th>Mã/Tên cột</th><th>Loại</th><th class="text-center">Hiển thị</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyConfigItems"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary mb-0" data-bs-dismiss="modal">Đóng</button>
                <button id="btnSaveConfig" class="btn btn-info mb-0">Lưu cấu hình</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Upload Excel -->
<div class="modal fade" id="modalUploadExcel" tabindex="-1">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content border-0">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Upload dữ liệu Excel</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 d-flex flex-column">
                <div class="p-3 bg-light border-bottom">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <input type="file" id="fileInputExcel" class="form-control" accept=".xlsx, .xls">
                        </div>
                        <div class="col-md-6 text-end">
                            <span id="excelStatus" class="me-3 fw-bold"></span>
                            <button id="btnStartUpload" class="btn btn-success mb-0" disabled>
                                <i class="fas fa-check me-1"></i> Bắt đầu Import
                            </button>
                        </div>
                    </div>
                </div>
                <div class="flex-grow-1 overflow-auto">
                    <table class="table table-sm align-items-center mb-0 text-xxs" id="tableExcelPreview">
                        <thead class="bg-gray-100 position-sticky top-0" id="theadExcelPreview"></thead>
                        <tbody id="tbodyExcelPreview"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Xem chi tiết phiếu lương -->
<div class="modal fade" id="modalViewDetail" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-gradient-info text-white">
                <div>
                    <h5 class="modal-title text-white" id="modalDetailName">Chi tiết phiếu lương</h5>
                    <p class="text-xs mb-0 opacity-8" id="modalDetailEmpCd"></p>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table align-items-center mb-0">
                        <thead class="bg-gray-100">
                            <tr>
                                <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Hạng mục</th>
                                <th class="text-end text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 pe-4">Giá trị</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyDetailItems"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary mb-0" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="~/Scripts/payslip_admin.js" asp-append-version="true"></script>
}
