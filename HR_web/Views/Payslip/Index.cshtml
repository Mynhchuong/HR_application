@{
    ViewData["Title"] = "Phiếu lương cá nhân";
}

<div class="container-fluid py-4">
    <div class="row">
        <!-- 1. Chọn Kỳ lương -->
        <div class="col-md-5 mx-auto mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-3">
                    <label class="form-label fw-bold">Chọn tháng xem lương</label>
                    <div class="input-group">
                        <select id="selectPeriod" class="form-select border ps-3" style="height: 45px;">
                            <option value="">-- Chọn kỳ lương --</option>
                            @foreach (var p in ViewBag.Periods)
                            {
                                <option value="@p.ID.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                        data-remark="@p.REMARK">@p.PERIOD_NAME</option>
                            }
                        </select>
                        <button id="btnViewPayslip" class="btn btn-primary mb-0 px-4">
                            <i class="fas fa-search"></i> Xem
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Hiển thị chi tiết phiếu lương -->
        <div class="col-12" id="divPayslipDetail" style="display:none;">
            <div class="card shadow-sm border-0 overflow-hidden">
                <div class="card-header bg-gradient-primary p-4 text-center">
                    <h5 class="text-white mb-0" id="hPeriodName">---</h5>
                    <p class="text-white opacity-8 mb-0" id="pEmpInfo">
                        Mã thẻ: @(ViewBag.CurrentUser?.EmpCd) - @(ViewBag.CurrentUser?.FullName)
                    </p>
                </div>
                <div id="divRemark" class="alert alert-info mx-4 mt-3 mb-0 text-white" style="display:none; border:none; border-radius: 8px;">
                    <i class="fas fa-bullhorn me-2"></i><strong>Thông báo từ HR:</strong> <span id="spanRemark"></span>
                </div>
                <div class="card-body p-0">
                    <div class="p-4 bg-light text-center border-bottom">
                        <span class="text-uppercase text-xs font-weight-bold text-secondary">Số tiền thực nhận</span>
                        <h2 class="text-dark mb-0" id="hThucLanh">0 VNĐ</h2>
                    </div>
                    <div class="row g-0">
                        <div class="col-lg-4 border-end">
                            <div class="p-3 bg-gray-100 border-bottom d-flex align-items-center">
                                <i class="fas fa-plus-circle text-success me-2"></i>
                                <span class="fw-bold text-uppercase text-xs">CÁC KHOẢN THU NHẬP</span>
                            </div>
                            <div id="divIncome" class="p-3"></div>
                        </div>
                        <div class="col-lg-4 border-end">
                            <div class="p-3 bg-gray-100 border-bottom d-flex align-items-center">
                                <i class="fas fa-minus-circle text-danger me-2"></i>
                                <span class="fw-bold text-uppercase text-xs">CÁC KHOẢN KHẤU TRỪ</span>
                            </div>
                            <div id="divDeduct" class="p-3"></div>
                        </div>
                        <div class="col-lg-4">
                            <div class="p-3 bg-gray-100 border-bottom d-flex align-items-center">
                                <i class="fas fa-info-circle text-info me-2"></i>
                                <span class="fw-bold text-uppercase text-xs">THÔNG TIN KHÁC (NGÀY CÔNG / PHÉP)</span>
                            </div>
                            <div id="divInfo" class="p-3"></div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-gray-100 p-3 text-center">
                    <p class="text-xs text-secondary mb-0">Mọi thắc mắc vui lòng liên hệ phòng Nhân sự để được giải đáp.</p>
                </div>
            </div>
        </div>

        <div id="divNoData" class="col-12 text-center py-5" style="display:none;">
            <img src="~/assets/img/illustrations/Sayhii.png" style="max-width: 200px;" class="mb-3 opacity-5" />
            <h6 class="text-secondary">Chưa có dữ liệu cho kỳ lương này hoặc phiếu lương chưa được công bố.</h6>
        </div>
    </div>
</div>

<style>
    .payslip-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed #e9ecef; }
    .payslip-row:last-child { border-bottom: none; }
    .payslip-label { font-size: 0.85rem; color: #495057; }
    .payslip-value { font-weight: 600; font-size: 0.85rem; color: #212529; }
    .text-total { color: #5e72e4 !important; font-weight: 800 !important; }
</style>

@section Scripts {
    <script src="~/Scripts/payslip_user.js" asp-append-version="true"></script>
}
