@using HR_web.Helpers
@{
    var layoutUser = AuthHelper.GetCurrentUser(User);
    var rawName = layoutUser?.FullName ?? layoutUser?.EmpCd ?? "User";
    var displayName = rawName;
    if (!string.IsNullOrEmpty(rawName))
    {
        var nameParts = rawName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (nameParts.Length >= 3)
        {
            displayName = nameParts[0] + " ... " + nameParts[nameParts.Length - 1];
        }
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - My SAMHO</title>

    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Material Dashboard CSS -->
    <link href="~/assets/css/nucleo-icons.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/assets/css/nucleo-svg.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/assets/css/material-dashboard.css?v=3.2.0" rel="stylesheet" asp-append-version="true" />

    <!-- Select2 CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" rel="stylesheet" />

    @RenderSection("Styles", required: false)

    <style>
        @@font-face {
            font-family: 'Vnitbi__';
            src: url('https://static.wfonts.com/data/2015/01/01/vni-times/Vnitbi__.ttf') format('truetype');
            font-display: swap;
        }
        .vni-font {
            font-family: 'Vnitbi__', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
        }
        :root {
            --header-height: 64px;
            --header-accent: linear-gradient(135deg, #1f2937 0%, #334155 45%, #2563eb 100%);
            --header-surface: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            --header-border: rgba(148, 163, 184, 0.22);
            --header-title: #334155;
            --header-subtle: #64748b;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
        }

        /* Premium Toast Styling */
        .alert-toast {
            border-radius: 16px !important;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.2) !important;
            margin-bottom: 1rem;
            animation: toastSlideIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            overflow: hidden;
        }

        .alert-toast.text-bg-success { background: rgba(45, 206, 137, 0.85) !important; }
        .alert-toast.text-bg-danger { background: rgba(245, 54, 88, 0.85) !important; }
        .alert-toast.text-bg-warning { background: rgba(251, 99, 64, 0.85) !important; color: #fff !important; }
        .alert-toast.text-bg-info { background: rgba(17, 205, 239, 0.85) !important; }

        @@keyframes toastSlideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        /* Sidebar tùy chỉnh - hr_web */
        #hr-sidebar {
            width: 250px;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            transform: translateX(0);
            background-color: #fff;
            z-index: 1030;
            overflow-y: auto;
            transition: left 0.3s ease, transform 0.3s ease;
            box-shadow: 0 0 15px rgba(0,0,0,0.05);
            border-right: 1px solid #eee;
        }

        .main-content {
            margin-left: 250px;
            padding: 0;
            transition: margin-left 0.3s ease;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Desktop: sidebar hidden */
        body.hr-menu-hidden #hr-sidebar {
            left: -250px;
        }

        body.hr-menu-hidden .main-content {
            margin-left: 0 !important;
        }

        /* ===== MOBILE SIDEBAR (hr_web) ===== */
        @@media (max-width: 991.98px) {
            #hr-sidebar {
                left: 0 !important;
                display: block !important;
                transform: translateX(-100%) !important;
                visibility: hidden;
                pointer-events: none;
            }
            .main-content {
                margin-left: 0 !important;
            }
            body.hr-mobile-open #hr-sidebar {
                transform: translateX(0) !important;
                visibility: visible;
                pointer-events: auto;
                z-index: 1032 !important;
                box-shadow: 0 8px 32px rgba(0,0,0,0.15) !important;
            }
            body.hr-mobile-open {
                overflow: hidden !important;
            }
            /* Backdrop */
            .hr-backdrop {
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.5);
                backdrop-filter: blur(4px);
                z-index: 1031;
                display: none;
            }
            body.hr-mobile-open .hr-backdrop {
                display: block;
            }
        }

        .main-body {
            flex: 1;
            padding: 1rem;
        }

        .main-header {
            position: sticky;
            top: 0;
            z-index: 1025;
            min-height: var(--header-height);
            padding: 1rem 1.5rem;
            background: #f8fafc;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .main-header-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            background: #ffffff;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }

        .main-header-left,
        .main-header-right {
            display: flex;
            align-items: center;
            min-width: 0;
        }

        .main-header-left {
            gap: 0.75rem;
            flex: 1;
        }

        .main-header-right {
            flex-shrink: 0;
        }

        .header-toggle-btn {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            color: #475569 !important;
            transition: all 0.2s ease;
        }

        .header-toggle-btn:hover,
        .header-toggle-btn:focus {
            background: #e2e8f0;
            color: #0f172a !important;
            transform: translateY(-1px);
        }

        .header-title {
            display: block;
            max-width: 100%;
            color: #1e293b;
            font-size: 1.1rem;
            font-weight: 800;
            line-height: 1.2;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            letter-spacing: -0.02em;
        }

        .header-user-toggle {
            max-width: 250px;
            padding: 0.45rem 0.8rem !important;
            border-radius: 50px !important;
            border: none;
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%) !important;
            color: #ffffff !important;
            font-size: 0.9rem;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        }

        .header-user-toggle::after {
            margin-left: 0.45rem;
            color: #ffffff !important;
        }

        .header-user-icon {
            width: 28px;
            height: 28px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.2) !important;
            color: #ffffff !important;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .header-user-name {
            display: inline-block;
            min-width: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: 0.9rem;
            font-weight: 600;
            color: #ffffff !important;
        }

        .app-footer {
            font-size: 10.5px;
            padding: 15px 0;
            color: #9aa0a6;
            text-align: center;
            opacity: 0.85;
            background: #f8f9fa;
        }

        /* Loading Overlay */
        #pageLoadingOverlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(4px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 18px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
        }
        #pageLoadingOverlay.show {
            opacity: 1;
            pointer-events: all;
        }
        .loading-spinner-ring {
            width: 56px;
            height: 56px;
            border: 5px solid #e0e7ff;
            border-top-color: #5e72e4;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @@media (max-width: 991.98px) {
            .main-header {
                padding: 0.75rem 1rem;
            }

            .main-header-bar {
                padding: 0.4rem 0.75rem;
                border-radius: 16px;
            }

            .header-title {
                font-size: 1rem;
            }

            .header-user-toggle {
                border: none;
                box-shadow: none;
                padding: 0.25rem !important;
            }

            .header-user-name {
                display: none; /* Hide full name on mobile */
            }
            
            .header-user-toggle::after {
                display: none;
            }
        }

        /* ===== MOBILE BOTTOM NAV ===== */
        .mobile-bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 68px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            display: none;
            justify-content: space-around;
            align-items: center;
            z-index: 1020;
            border-top: 1px solid rgba(0, 0, 0, 0.05);
            padding: 0 10px;
            box-shadow: 0 -5px 20px rgba(0,0,0,0.03);
        }

        .nav-item-mobile {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-decoration: none !important;
            color: #94a3b8;
            transition: all 0.2s ease;
            width: 25%;
        }

        .nav-item-mobile.active {
            color: #2563eb;
        }

        .nav-item-mobile .icon-wrap {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            transition: all 0.2s ease;
        }

        .nav-item-mobile.active .icon-wrap {
            background: rgba(37, 99, 235, 0.1);
        }

        .nav-item-mobile .material-symbols-rounded {
            font-size: 24px;
        }

        .nav-item-mobile span.nav-text {
            font-size: 10px;
            font-weight: 700;
            margin-top: 4px;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        @@media (max-width: 991.98px) {
            .mobile-bottom-nav {
                display: flex;
            }
            .main-body {
                padding-bottom: 80px; /* Space for bottom nav */
            }
            .app-footer {
                padding-bottom: 85px;
            }
        }

        @@keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body class="bg-gray-100">

    <!-- Sidenav Backdrop for mobile -->
    <div class="hr-backdrop"></div>

    <!-- Loading Overlay -->
    <div id="pageLoadingOverlay">
        <div class="loading-spinner-ring"></div>
        <div class="fw-bold text-primary">Đang tải dữ liệu...</div>
    </div>

    <!-- Toast Alerts Container -->
    <div id="toast-container" class="position-fixed top-0 end-0 p-3" style="z-index: 9998;">
        @Html.RenderAlerts()
    </div>

    <!-- Sidebar (hr_web) -->
    <aside id="hr-sidebar" class="sidenav navbar navbar-vertical navbar-expand-xs border-0 fixed-start bg-white">
        @await Html.PartialAsync("_SideNav")
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <div class="main-header shadow-sm">
            <div class="main-header-bar">
            <div class="main-header-left">
                <button id="hr-btnToggle" class="btn btn-link border-0 shadow-none header-toggle-btn" type="button" aria-label="Toggle menu" aria-expanded="false">
                    <span class="material-symbols-rounded" style="font-size: 1.35rem;">menu</span>
                </button>
                <div class="header-title-wrap ms-1">
                    <span class="header-title" title="@ViewData["Title"]">@ViewData["Title"]</span>
                </div>
            </div>

            <div class="main-header-right">
                <div class="dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 header-user-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <span class="header-user-icon">
                            <span class="material-symbols-rounded">person</span>
                        </span>
                        <span class="header-user-name vni-font" title="@rawName">@displayName</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg" style="border-radius: 16px;">
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2 py-2" asp-controller="Profile" asp-action="ProfileUser">
                                <span class="material-symbols-rounded text-primary" style="font-size: 1.2rem;">account_circle</span> Hồ sơ
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item text-danger d-flex align-items-center gap-2 py-2" href="javascript:;" data-bs-toggle="modal" data-bs-target="#logoutModal">
                                <span class="material-symbols-rounded" style="font-size: 1.2rem;">logout</span> Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
            </div>
        </div>

        <!-- Body -->
        <section class="main-body">
            @RenderBody()
        </section>

        <!-- Footer -->
        <footer class="app-footer">
            © 2026 VietNam Samho Co., LTD · Powered by IT Team
        </footer>
    </main>

    <!-- Mobile Bottom Navigation -->
    <nav class="mobile-bottom-nav">
        <a href="@Url.Content("~/Home/Index")" class="nav-item-mobile @(Context.Request.Path.Value?.Contains("/Home") == true ? "active" : "")">
            <div class="icon-wrap">
                <span class="material-symbols-rounded">@(Context.Request.Path.Value?.Contains("/Home") == true ? "home" : "home")</span>
            </div>
            <span class="nav-text">Home</span>
        </a>
        <a href="@Url.Content("~/Payslip/Index")" class="nav-item-mobile @(Context.Request.Path.Value?.Contains("/Payslip") == true ? "active" : "")">
            <div class="icon-wrap">
                <span class="material-symbols-rounded">payments</span>
            </div>
            <span class="nav-text">Lương</span>
        </a>
        <a href="@Url.Content("~/OT/OtConfirmForm")" class="nav-item-mobile @(Context.Request.Path.Value?.Contains("/OT") == true ? "active" : "")">
            <div class="icon-wrap">
                <span class="material-symbols-rounded">history_edu</span>
            </div>
            <span class="nav-text">Tăng ca</span>
        </a>
        <a href="@Url.Content("~/Profile/ProfileUser")" class="nav-item-mobile @(Context.Request.Path.Value?.Contains("/Profile") == true ? "active" : "")">
            <div class="icon-wrap">
                <span class="material-symbols-rounded">person</span>
            </div>
            <span class="nav-text">Hồ sơ</span>
        </a>
    </nav>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js"></script>
    <!-- Alert Helper -->
    <script src="~/Scripts/alert-helper.js" asp-append-version="true"></script>
    <!-- Select2 Helper -->
    <script src="~/assets/js/select2-helper.js" asp-append-version="true"></script>

    <!-- Material Dashboard JS -->
    <script src="~/assets/js/plugins/perfect-scrollbar.min.js" asp-append-version="true"></script>
    <script src="~/assets/js/material-dashboard.min.js?v=3.2.0" asp-append-version="true"></script>

    <script>
        window.showLoading = function () {
            document.getElementById('pageLoadingOverlay')?.classList.add('show');
        };

        window.hideLoading = function () {
            document.getElementById('pageLoadingOverlay')?.classList.remove('show');
        };

        $(document).ready(function () {
            var body = document.body;
            var btnToggle = document.getElementById("hr-btnToggle");
            var btnCloseSidebar = document.getElementById("hr-iconSidenav");
            var backdrop = document.querySelector(".hr-backdrop");
            var isMobile = function () { return window.innerWidth <= 991.98; };
            var setMobileSidebar = function (isOpen) {
                body.classList.toggle("hr-mobile-open", isOpen);
                if (btnToggle) {
                    btnToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
                }
            };

            function toggleSidebar() {
                if (isMobile()) {
                    setMobileSidebar(!body.classList.contains("hr-mobile-open"));
                } else {
                    body.classList.toggle("hr-menu-hidden");
                    localStorage.setItem("hr_menu_hidden", body.classList.contains("hr-menu-hidden"));
                }
            }

            function syncDesktopState() {
                if (!isMobile()) {
                    setMobileSidebar(false);
                    if (localStorage.getItem("hr_menu_hidden") === "true") {
                        body.classList.add("hr-menu-hidden");
                    } else {
                        body.classList.remove("hr-menu-hidden");
                    }
                }
            }

            // Khởi tạo trạng thái
            syncDesktopState();

            if (btnToggle) {
                btnToggle.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    toggleSidebar();
                });
            }

            if (btnCloseSidebar) {
                btnCloseSidebar.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    setMobileSidebar(false);
                });
            }

            if (backdrop) {
                backdrop.addEventListener("click", function() {
                    setMobileSidebar(false);
                });
            }

            window.addEventListener("resize", function() {
                if (!isMobile()) {
                    syncDesktopState();
                } else {
                    body.classList.remove("hr-menu-hidden");
                }
            });

            $('a').not('[target="_blank"]').not('[href^="#"]').not('[data-bs-toggle]').on('click', function() {
                if (!$(this).hasClass('dropdown-toggle')) {
                    window.showLoading();
                }
            });
        });

        window.addEventListener('load', function () {
            window.hideLoading();
        });
    </script>

    <!-- Logout Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 28px;">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3">
                        <div class="bg-soft-orange rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                            <span class="material-symbols-rounded text-warning" style="font-size: 2.5rem;">logout</span>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-2">Đăng xuất?</h5>
                    <p class="text-muted small mb-4">Bạn có chắc chắn muốn thoát khỏi hệ thống không?</p>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-light w-100 py-2 rounded-3 fw-bold" data-bs-dismiss="modal">Hủy</button>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="w-100">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger w-100 py-2 rounded-3 fw-bold">Thoát</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
