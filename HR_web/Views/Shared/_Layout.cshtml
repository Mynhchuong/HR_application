@using HR_web.Helpers
@{
    var layoutUser = AuthHelper.GetCurrentUser(User);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - HR Application</title>

    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Material Dashboard CSS -->
    <link href="~/assets/css/nucleo-icons.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/assets/css/nucleo-svg.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/assets/css/material-dashboard.css?v=3.2.0" rel="stylesheet" asp-append-version="true" />

    <!-- Select2 CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" rel="stylesheet" />

    @RenderSection("Styles", required: false)

    <style>
        :root {
            --header-height: 60px;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
        }

        /* Sidebar */
        #sidebar {
            width: 250px;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            background-color: #fff;
            z-index: 1020;
            overflow-y: auto;
            border-right: 1px solid #e0e0e0;
        }

        .sidenav-header {
            display: flex;
            align-items: center;
            height: var(--header-height);
            padding: 0 1rem;
        }

        .navbar-nav .nav-link.active {
            font-weight: bold;
            background-color: #f0f0f0;
        }

        /* Main Content */
        .main-content {
            margin-left: 270px;
            padding: 0;
            transition: all 0.2s ease-in-out;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Desktop: sidebar pinned */
        .g-sidenav-pinned .main-content {
            margin-left: 270px;
        }
        
        /* Desktop: sidebar hidden */
        body:not(.g-sidenav-pinned) .main-content {
            margin-left: 0 !important;
        }

        body:not(.g-sidenav-pinned) #sidenav-main {
            transform: translateX(-300px);
        }

        #sidenav-main {
            transition: all 0.2s ease-in-out;
            z-index: 1030;
        }

        /* Mobile Optimization */
        @@media (max-width: 1199.98px) {
            .main-content {
                margin-left: 0 !important;
            }
            #sidenav-main {
                transform: translateX(-300px);
                margin-left: 0 !important;
                left: 0 !important;
                height: 100vh !important;
                top: 0 !important;
                margin-top: 0 !important;
                border-radius: 0 !important;
                width: 260px !important;
            }
            .g-sidenav-show #sidenav-main {
                transform: translateX(0);
                box-shadow: 0 8px 10px -5px rgba(0,0,0,.2),0 16px 24px 2px rgba(0,0,0,.14),0 6px 30px 5px rgba(0,0,0,.12) !important;
            }
            
            /* Sidenav backdrop for mobile */
            .sidenav-backdrop {
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background-color: rgba(0, 0, 0, 0.5);
                z-index: 1025;
                display: none;
                backdrop-filter: blur(2px);
                -webkit-backdrop-filter: blur(2px);
            }
            .g-sidenav-show .sidenav-backdrop {
                display: block;
            }
        }

        /* Header */
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: var(--header-height);
            padding: 0 1rem;
            background-color: #fff;
            border-bottom: 1px solid #e0e0e0;
            position: sticky;
            top: 0;
            z-index: 1010;
        }

        .main-body {
            flex: 1;
            padding: 1rem;
        }

        .app-footer {
            font-size: 10.5px;
            padding: 15px 0;
            color: #9aa0a6;
            text-align: center;
            opacity: 0.85;
            background: #f8f9fa;
        }

        /* Loading Overlay */
        #pageLoadingOverlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(4px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 18px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
        }
        #pageLoadingOverlay.show {
            opacity: 1;
            pointer-events: all;
        }
        .loading-spinner-ring {
            width: 56px;
            height: 56px;
            border: 5px solid #e0e7ff;
            border-top-color: #5e72e4;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body class="bg-gray-100 g-sidenav-pinned">

    <!-- Sidenav Backdrop for mobile -->
    <div class="sidenav-backdrop" onclick="toggleSidebarMobile()"></div>

    <!-- Loading Overlay -->
    <div id="pageLoadingOverlay">
        <div class="loading-spinner-ring"></div>
        <div class="fw-bold text-primary">Đang tải dữ liệu...</div>
    </div>

    <!-- Toast Alerts Container -->
    <div id="toast-container" class="position-fixed top-0 end-0 p-3" style="z-index: 9998;">
        @Html.RenderAlerts()
    </div>

    <!-- Sidebar: render từ _SideNav partial -->
    <aside id="sidenav-main" class="sidenav navbar navbar-vertical navbar-expand-xs border-0 border-radius-xl my-3 fixed-start ms-3">
        @await Html.PartialAsync("_SideNav")
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <div class="main-header">
            <div class="d-flex align-items-center">
                <button id="iconNavbarSidenav" class="btn btn-link text-dark p-0 border-0 me-3">
                    <span class="material-symbols-rounded">menu</span>
                </button>
                <span class="fw-bold">@ViewData["Title"]</span>
            </div>

            <div class="d-flex align-items-center">
                <div class="dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="material-symbols-rounded me-1">account_circle</i>
                        <span>@(layoutUser?.FullName ?? layoutUser?.EmpCd ?? "User")</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                        <li><a class="dropdown-item" asp-controller="Profile" asp-action="ProfileUser"><i class="fas fa-user me-2"></i>Hồ sơ</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline" id="logoutFormHeader">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Đăng xuất?')">
                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Body -->
        <section class="main-body">
            @RenderBody()
        </section>

        <!-- Footer -->
        <footer class="app-footer">
            © 2026 VietNam Samho Co., LTD · Powered by IT Team
        </footer>
    </main>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js"></script>
    <!-- Select2 Helper -->
    <script src="~/assets/js/select2-helper.js" asp-append-version="true"></script>

    <!-- Material Dashboard JS -->
    <script src="~/assets/js/plugins/perfect-scrollbar.min.js" asp-append-version="true"></script>
    <script src="~/assets/js/material-dashboard.min.js?v=3.2.0" asp-append-version="true"></script>

    <script>
        // Toggle Sidebar - MD3 Standard Optimized
        function toggleSidebarMobile() {
            document.body.classList.remove("g-sidenav-show");
        }

        $(document).ready(function () {
            // Loading Overlay
            window.showLoading = () => document.getElementById('pageLoadingOverlay').classList.add('show');
            window.hideLoading = () => document.getElementById('pageLoadingOverlay').classList.remove('show');
            
            $('a').not('[target="_blank"]').not('[href^="#"]').not('[data-bs-toggle]').on('click', function() {
                showLoading();
            });
        });

        window.onload = () => hideLoading();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
