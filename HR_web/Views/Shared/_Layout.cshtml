@using HR_web.Helpers
@{
    var layoutUser = AuthHelper.GetCurrentUser(User);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - HR Application</title>

    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Material Dashboard CSS -->
    <link href="~/assets/css/nucleo-icons.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/assets/css/nucleo-svg.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/assets/css/material-dashboard.css?v=3.2.0" rel="stylesheet" asp-append-version="true" />

    <!-- Select2 CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" rel="stylesheet" />

    @RenderSection("Styles", required: false)

    <style>
        :root {
            --header-height: 64px;
            --header-accent: linear-gradient(135deg, #1f2937 0%, #334155 45%, #2563eb 100%);
            --header-surface: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            --header-border: rgba(148, 163, 184, 0.22);
            --header-title: #334155;
            --header-subtle: #64748b;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
        }

        /* Sidebar tùy chỉnh - hr_web */
        #hr-sidebar {
            width: 250px;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            transform: translateX(0);
            background-color: #fff;
            z-index: 1060;
            overflow-y: auto;
            transition: left 0.3s ease, transform 0.3s ease;
            box-shadow: 0 0 15px rgba(0,0,0,0.05);
            border-right: 1px solid #eee;
        }

        .main-content {
            margin-left: 250px;
            padding: 0;
            transition: margin-left 0.3s ease;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Desktop: sidebar hidden */
        body.hr-menu-hidden #hr-sidebar {
            left: -250px;
        }

        body.hr-menu-hidden .main-content {
            margin-left: 0 !important;
        }

        /* ===== MOBILE SIDEBAR (hr_web) ===== */
        @@media (max-width: 991.98px) {
            #hr-sidebar {
                left: 0 !important;
                display: block !important;
                transform: translateX(-100%) !important;
                visibility: hidden;
                pointer-events: none;
            }
            .main-content {
                margin-left: 0 !important;
            }
            body.hr-mobile-open #hr-sidebar {
                transform: translateX(0) !important;
                visibility: visible;
                pointer-events: auto;
                z-index: 1070 !important;
                box-shadow: 0 8px 32px rgba(0,0,0,0.15) !important;
            }
            body.hr-mobile-open {
                overflow: hidden !important;
            }
            /* Backdrop */
            .hr-backdrop {
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.5);
                backdrop-filter: blur(4px);
                z-index: 1065;
                display: none;
            }
            body.hr-mobile-open .hr-backdrop {
                display: block;
            }
        }

        .main-body {
            flex: 1;
            padding: 1rem;
        }

        .main-header {
            position: sticky;
            top: 0;
            z-index: 1040;
            min-height: var(--header-height);
            padding: 0.75rem 1rem;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--header-border);
        }

        .main-header-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.55rem 0.75rem;
            border-radius: 18px;
            background: var(--header-surface);
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
        }

        .main-header-left,
        .main-header-right {
            display: flex;
            align-items: center;
            min-width: 0;
        }

        .main-header-left {
            gap: 0.75rem;
            flex: 1;
        }

        .main-header-right {
            flex-shrink: 0;
        }

        .header-toggle-btn {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--header-accent);
            color: #fff !important;
            box-shadow: 0 10px 18px rgba(37, 99, 235, 0.28);
        }

        .header-toggle-btn:hover,
        .header-toggle-btn:focus {
            color: #fff !important;
            transform: translateY(-1px);
        }

        .header-title-wrap {
            min-width: 0;
        }

        .header-title-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            margin-bottom: 0.15rem;
            padding: 0.18rem 0.5rem;
            border-radius: 999px;
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: #2563eb;
            background: rgba(37, 99, 235, 0.10);
        }

        .header-title {
            display: block;
            max-width: 100%;
            color: var(--header-title);
            font-size: 1.02rem;
            font-weight: 700;
            line-height: 1.2;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .header-user-toggle {
            max-width: min(38vw, 210px);
            padding: 0.45rem 0.7rem !important;
            border-radius: 14px;
            border: 1px solid rgba(148, 163, 184, 0.2);
            background: #fff;
            color: var(--header-subtle) !important;
            font-size: 0.9rem;
            box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
        }

        .header-user-toggle::after {
            margin-left: 0.45rem;
        }

        .header-user-icon {
            width: 28px;
            height: 28px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(37, 99, 235, 0.12);
            color: #2563eb;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .header-user-name {
            display: inline-block;
            min-width: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: 0.86rem;
            font-weight: 600;
            color: var(--header-subtle);
        }

        .app-footer {
            font-size: 10.5px;
            padding: 15px 0;
            color: #9aa0a6;
            text-align: center;
            opacity: 0.85;
            background: #f8f9fa;
        }

        /* Loading Overlay */
        #pageLoadingOverlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(4px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 18px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
        }
        #pageLoadingOverlay.show {
            opacity: 1;
            pointer-events: all;
        }
        .loading-spinner-ring {
            width: 56px;
            height: 56px;
            border: 5px solid #e0e7ff;
            border-top-color: #5e72e4;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @@media (max-width: 991.98px) {
            .main-header {
                padding: 0.45rem 0.6rem;
            }

            .main-header-bar {
                padding: 0.45rem 0.55rem;
                gap: 0.5rem;
                border-radius: 16px;
            }

            .main-header-left {
                gap: 0.55rem;
            }

            .header-toggle-btn {
                width: 36px;
                height: 36px;
                border-radius: 12px;
            }

            .header-toggle-btn .material-symbols-rounded {
                font-size: 1.15rem !important;
            }

            .header-title-badge {
                display: none;
            }

            .header-title {
                font-size: 0.92rem;
            }

            .header-user-toggle {
                max-width: 128px;
                padding: 0.35rem 0.55rem !important;
                font-size: 0.82rem;
            }

            .header-user-icon {
                width: 24px;
                height: 24px;
                font-size: 0.92rem;
            }

            .header-user-name {
                font-size: 0.78rem;
            }
        }

        @@keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body class="bg-gray-100">

    <!-- Sidenav Backdrop for mobile -->
    <div class="hr-backdrop"></div>

    <!-- Loading Overlay -->
    <div id="pageLoadingOverlay">
        <div class="loading-spinner-ring"></div>
        <div class="fw-bold text-primary">Đang tải dữ liệu...</div>
    </div>

    <!-- Toast Alerts Container -->
    <div id="toast-container" class="position-fixed top-0 end-0 p-3" style="z-index: 9998;">
        @Html.RenderAlerts()
    </div>

    <!-- Sidebar (hr_web) -->
    <aside id="hr-sidebar" class="sidenav navbar navbar-vertical navbar-expand-xs border-0 fixed-start bg-white">
        @await Html.PartialAsync("_SideNav")
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <div class="main-header shadow-sm">
            <div class="main-header-bar">
            <div class="main-header-left">
                <button id="hr-btnToggle" class="btn btn-link border-0 shadow-none header-toggle-btn" type="button" aria-label="Toggle menu" aria-expanded="false">
                    <span class="material-symbols-rounded" style="font-size: 1.35rem;">menu</span>
                </button>
                <div class="header-title-wrap">
                    <span class="header-title-badge">Workspace</span>
                    <span class="header-title" title="@ViewData["Title"]">@ViewData["Title"]</span>
                </div>
            </div>

            <div class="main-header-right">
                <div class="dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 header-user-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <span class="header-user-icon">
                            <i class="material-symbols-rounded">account_circle</i>
                        </span>
                        <span class="header-user-name" title="@(layoutUser?.FullName ?? layoutUser?.EmpCd ?? "User")">@(layoutUser?.FullName ?? layoutUser?.EmpCd ?? "User")</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                        <li><a class="dropdown-item" asp-controller="Profile" asp-action="ProfileUser"><i class="fas fa-user me-2"></i>Hồ sơ</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline" id="logoutFormHeader">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Đăng xuất?')">
                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
            </div>
        </div>

        <!-- Body -->
        <section class="main-body">
            @RenderBody()
        </section>

        <!-- Footer -->
        <footer class="app-footer">
            © 2026 VietNam Samho Co., LTD · Powered by IT Team
        </footer>
    </main>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js"></script>
    <!-- Select2 Helper -->
    <script src="~/assets/js/select2-helper.js" asp-append-version="true"></script>

    <!-- Material Dashboard JS -->
    <script src="~/assets/js/plugins/perfect-scrollbar.min.js" asp-append-version="true"></script>
    <script src="~/assets/js/material-dashboard.min.js?v=3.2.0" asp-append-version="true"></script>

    <script>
        window.showLoading = function () {
            document.getElementById('pageLoadingOverlay')?.classList.add('show');
        };

        window.hideLoading = function () {
            document.getElementById('pageLoadingOverlay')?.classList.remove('show');
        };

        $(document).ready(function () {
            var body = document.body;
            var btnToggle = document.getElementById("hr-btnToggle");
            var btnCloseSidebar = document.getElementById("hr-iconSidenav");
            var backdrop = document.querySelector(".hr-backdrop");
            var isMobile = function () { return window.innerWidth <= 991.98; };
            var setMobileSidebar = function (isOpen) {
                body.classList.toggle("hr-mobile-open", isOpen);
                if (btnToggle) {
                    btnToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
                }
            };

            function toggleSidebar() {
                if (isMobile()) {
                    setMobileSidebar(!body.classList.contains("hr-mobile-open"));
                } else {
                    body.classList.toggle("hr-menu-hidden");
                    localStorage.setItem("hr_menu_hidden", body.classList.contains("hr-menu-hidden"));
                }
            }

            function syncDesktopState() {
                if (!isMobile()) {
                    setMobileSidebar(false);
                    if (localStorage.getItem("hr_menu_hidden") === "true") {
                        body.classList.add("hr-menu-hidden");
                    } else {
                        body.classList.remove("hr-menu-hidden");
                    }
                }
            }

            // Khởi tạo trạng thái
            syncDesktopState();

            if (btnToggle) {
                btnToggle.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    toggleSidebar();
                });
            }

            if (btnCloseSidebar) {
                btnCloseSidebar.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    setMobileSidebar(false);
                });
            }

            if (backdrop) {
                backdrop.addEventListener("click", function() {
                    setMobileSidebar(false);
                });
            }

            window.addEventListener("resize", function() {
                if (!isMobile()) {
                    syncDesktopState();
                } else {
                    body.classList.remove("hr-menu-hidden");
                }
            });

            $('a').not('[target="_blank"]').not('[href^="#"]').not('[data-bs-toggle]').on('click', function() {
                if (!$(this).hasClass('dropdown-toggle')) {
                    window.showLoading();
                }
            });
        });

        window.addEventListener('load', function () {
            window.hideLoading();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
