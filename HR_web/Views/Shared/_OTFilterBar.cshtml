@model HR_web.Models.OT.OTFilterBarModel

<div class="px-3 pt-3 pb-2 d-flex flex-wrap align-items-end gap-2 filter-bar" style="background:#f8fafc;border-bottom:1px solid #e9ecef;">

    <div style="min-width:140px;flex:1 1 140px;max-width:180px;">
        <label class="form-label small fw-bold mb-1 text-primary">Mã NV</label>
        <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="🔍 Tìm mã NV..." />
    </div>

    <div style="min-width:120px;flex:1 1 120px;max-width:160px;">
        <label class="form-label small fw-bold mb-1 text-primary">Tình Trạng</label>
        <select id="filterStatus" class="form-select form-select-sm">
            <option value="">Tất cả</option>
            <option value="PENDING">Chờ ký</option>
            <option value="CONFIRMED">Đã ký</option>
            <option value="REJECTED">Từ chối</option>
        </select>
    </div>

    <div style="min-width:150px;flex:2 1 150px;max-width:220px;">
        <label class="form-label small fw-bold mb-1 text-primary">Bộ Phận</label>
        <select id="filterDept" class="select2 form-control"
                data-url="@Model.DeptUrl"
                data-placeholder="Tất cả"
                data-selected-id="@Model.DeptSelectedId"></select>
    </div>

    <div style="min-width:140px;flex:2 1 140px;max-width:200px;">
        <label class="form-label small fw-bold mb-1 text-primary">Line</label>
        <select id="filterLine" class="select2 form-control"
                data-url="@Model.LineUrl"
                data-placeholder="Tất cả"></select>
    </div>

    <div style="min-width:140px;flex:2 1 140px;max-width:200px;">
        <label class="form-label small fw-bold mb-1 text-primary">Nhóm Việc</label>
        <select id="filterWork" class="select2 form-control"
                data-url="@Model.WorkUrl"
                data-placeholder="Tất cả"></select>
    </div>

    <div class="d-flex align-items-end gap-2 ms-auto">
        <div>
            <label class="form-label small fw-bold mb-1 text-secondary">Hiển thị</label>
            <select id="pageSizeSelect" class="form-select form-select-sm" style="width:80px;">
                <option value="50">50</option>
                <option value="100" selected>100</option>
                <option value="500">500</option>
            </select>
        </div>
        <span id="paginationInfo" class="text-nowrap pb-1"></span>
    </div>

</div>
