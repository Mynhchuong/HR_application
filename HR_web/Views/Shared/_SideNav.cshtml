@using HR_web.Helpers
@using HR_web.Models.Account

@{
    var user = AuthHelper.GetCurrentUser(User);
    var currentPath = Context.Request.Path.Value?.ToLower().TrimEnd('/') ?? "";
    var menus = SideMenuBuilder.Build(user);
    var menuThemes = new[]
    {
        "menu-theme-personal",
        "menu-theme-clerk",
        "menu-theme-manager",
        "menu-theme-hr"
    };

    // Tìm tiêu đề trang từ menu đang active
    string pageTitle = "";
    foreach (var menu in menus.Where(m => m.VisibleWhen?.Invoke() == true))
    {
        foreach (var item in menu.Children)
        {
            if (string.IsNullOrEmpty(item.Url)) continue;
            var menuPath = Url.Content(item.Url).ToLower().TrimEnd('/');
            if (currentPath.StartsWith(menuPath))
            {
                pageTitle = item.Title;
                break;
            }
        }
        if (!string.IsNullOrEmpty(pageTitle)) break;
    }
}

<style>
    .menu-icon-shell,
    .menu-child-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .menu-icon-shell {
        width: 34px;
        height: 34px;
        border-radius: 12px;
        margin-right: 0.65rem;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.10);
    }

    .menu-icon-shell .material-symbols-rounded {
        font-size: 1.1rem;
        color: #fff;
    }

    .menu-child-icon {
        width: 28px;
        height: 28px;
        border-radius: 10px;
        margin-right: 0.6rem;
        background: rgba(148, 163, 184, 0.14);
    }

    .menu-child-icon .material-symbols-rounded {
        font-size: 1rem;
    }

    .nav-link:hover .menu-icon-shell,
    .nav-link:hover .menu-child-icon {
        transform: translateY(-1px);
    }

    .menu-theme-personal > .nav-link .menu-icon-shell {
        background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
    }

    .menu-theme-personal .menu-child-icon,
    .menu-theme-personal .menu-child-icon .material-symbols-rounded {
        color: #ea580c;
    }

    .menu-theme-clerk > .nav-link .menu-icon-shell {
        background: linear-gradient(135deg, #06b6d4 0%, #2563eb 100%);
    }

    .menu-theme-clerk .menu-child-icon,
    .menu-theme-clerk .menu-child-icon .material-symbols-rounded {
        color: #0284c7;
    }

    .menu-theme-manager > .nav-link .menu-icon-shell {
        background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
    }

    .menu-theme-manager .menu-child-icon,
    .menu-theme-manager .menu-child-icon .material-symbols-rounded {
        color: #7c3aed;
    }

    .menu-theme-hr > .nav-link .menu-icon-shell {
        background: linear-gradient(135deg, #10b981 0%, #14b8a6 100%);
    }

    .menu-theme-hr .menu-child-icon,
    .menu-theme-hr .menu-child-icon .material-symbols-rounded {
        color: #059669;
    }

    .nav-link.active .menu-child-icon {
        background: rgba(255, 255, 255, 0.18);
    }
</style>

<!-- ===== SIDENAV HEADER ===== -->
<div class="sidenav-header">
    <i class="fas fa-times p-3 cursor-pointer text-dark opacity-5 position-absolute end-0 top-0 d-block d-lg-none"
       id="hr-iconSidenav"></i>

    <a class="navbar-brand px-4 py-4 m-0 d-flex align-items-center" style="border-bottom: 1px solid rgba(0,0,0,0.03);">
        <div class="d-flex align-items-center justify-content-center bg-white shadow-sm rounded-3 me-2" style="width: 42px; height: 42px; border: 1px solid #f1f5f9; flex-shrink: 0;">
            <img src="~/assets/img/samho-logo.png" class="navbar-brand-img" style="width: 30px; height: auto;" alt="logo" />
        </div>
        <div class="d-flex flex-column">
            <span class="fw-bolder" style="letter-spacing: -0.5px; line-height: 1.1;">
                <span style="color: #ed1c24; font-size: 1.25rem;">My</span> 
                <span style="color: #1e293b; font-size: 1.25rem;">SAMHO</span>
            </span>
            <span class="text-uppercase text-muted fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px; opacity: 0.8;">HR Portal</span>
        </div>
    </a>
</div>

<hr class="horizontal dark mt-0 mb-2" />

<!-- ===== SIDENAV MENU ===== -->
<div class="navbar-collapse w-auto max-height-vh-100 h-100" id="sidenav-collapse-main">
    <ul class="navbar-nav">

        @foreach (var menuEntry in menus.Where(m => m.VisibleWhen?.Invoke() == true).Select((menu, index) => new { menu, index }))
        {
            var menu = menuEntry.menu;
            var themeClass = menuThemes[menuEntry.index % menuThemes.Length];
            bool open = menu.Children.Any(c =>
                !string.IsNullOrEmpty(c.Url) &&
                currentPath.StartsWith(Url.Content(c.Url).ToLower())
            );

            <li class="nav-item mt-2 @themeClass">
                <a class="nav-link text-dark d-flex justify-content-between align-items-center"
                   data-bs-toggle="collapse"
                   href="#@menu.Id"
                   aria-expanded="@open.ToString().ToLower()">

                    <span class="d-flex align-items-center">
                        <span class="menu-icon-shell">
                            <i class="material-symbols-rounded">@menu.Icon</i>
                        </span>
                        <span class="nav-link-text">@menu.Title</span>
                    </span>

                    <i class="material-symbols-rounded">expand_more</i>
                </a>

                <div class="collapse ps-3 @(open ? "show" : "")" id="@menu.Id">
                    <ul class="navbar-nav">
                        @foreach (var item in menu.Children.Where(c => c.VisibleWhen == null || c.VisibleWhen()))
                        {
                            bool active = !string.IsNullOrEmpty(item.Url) &&
                                          currentPath.StartsWith(Url.Content(item.Url).ToLower());

                            <li class="nav-item">
                                <a class="nav-link text-dark rounded px-2 py-1 @(active ? "active fw-bold bg-light" : "")"
                                   href="@Url.Content(item.Url ?? "#")">
                                    <span class="menu-child-icon">
                                        <i class="material-symbols-rounded">@item.Icon</i>
                                    </span>
                                    <span class="nav-link-text">@item.Title</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </li>
        }

    </ul>
</div>

<!-- Sidenav Footer with Logout -->
<div class="sidenav-footer mx-3 my-3">
    <button class="btn btn-outline-danger w-100 border-2 d-flex align-items-center justify-content-center gap-2" 
            style="border-radius: 16px; padding: 12px; font-weight: 800;"
            data-bs-toggle="modal" data-bs-target="#logoutModal">
        <span class="material-symbols-rounded">logout</span>
        <span>Đăng xuất</span>
    </button>
</div>

