@model X.PagedList.IPagedList<HR_web.Models.Account.UserInfoModel>
@using HR_web.Helpers

@{ ViewData["Title"] = "User Management"; }

<div class="container-fluid py-2">

    <!-- FILTER -->
    <div class="card my-4 mb-5">
        <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
            <div class="bg-gradient-primary shadow-primary border-radius-lg pt-3 pb-2 px-3 d-flex justify-content-between align-items-center">
                <h6 class="text-white text-capitalize mb-0"><i class="fas fa-filter me-1"></i> Quản Lý Người Dùng</h6>
                <button type="button" class="btn bg-gradient-success mb-0 btn-sm"
                        data-bs-toggle="modal" data-bs-target="#createUserModal">
                    <i class="fas fa-user-plus me-1"></i> Khởi tạo User
                </button>
            </div>
        </div>
        <div class="card-body px-4 pb-3 pt-4">
            <form id="filterForm" method="get">
                <input type="hidden" name="pageSize" id="hiddenPageSize" value="@(ViewBag.PageSize ?? 50)" />
                <input type="hidden" name="page" id="hiddenPage" value="1" />
                <div class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <div class="input-group input-group-static">
                            <label>Mã Nhân Viên</label>
                            <input type="text" name="empCd" value="@ViewBag.EmpCd" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-bold mb-0 text-primary">Phòng ban (Dept)</label>
                        <select id="deptCd" name="deptCd" class="select2 form-control"
                                data-url="@Url.Action("GetDept", "Dropdown")" data-placeholder="Tất cả"></select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-bold mb-0 text-primary">Line</label>
                        <select id="lineCd" name="lineCd" class="select2 form-control"
                                data-url="@Url.Action("GetLine", "Dropdown")" data-parent="#deptCd" data-placeholder="Tất cả"></select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-bold mb-0 text-primary">Phân Quyền</label>
                        <select id="filterRoleId" name="roleId" class="select2 form-control"
                                data-url="@Url.Action("GetRole", "Dropdown")" data-placeholder="Tất cả"></select>
                    </div>
                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-dark flex-fill mb-0">TÌM KIẾM</button>
                        <button type="button" id="clearFilter" class="btn btn-outline-secondary flex-fill mb-0">XÓA</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card">
        <div class="card-body p-0">
            <div class="d-flex justify-content-between align-items-center px-4 pt-3 pb-2 border-bottom">
                <div class="d-flex align-items-center">
                    <span class="text-sm me-2 text-secondary">Hiển thị</span>
                    <select class="form-select form-select-sm border px-2 w-auto cursor-pointer"
                            onchange="document.getElementById('hiddenPageSize').value=this.value; document.getElementById('hiddenPage').value=1; document.getElementById('filterForm').submit();">
                        @{ var currentPageSize = (int)(ViewBag.PageSize ?? 50); }
                        @foreach (var size in new[] { 10, 25, 50, 100 })
                        {
                            if (currentPageSize == size)
                            {
                                <option value="@size" selected>@size</option>
                            }
                            else
                            {
                                <option value="@size">@size</option>
                            }
                        }
                    </select>
                    <span class="text-sm ms-2 text-secondary">dòng</span>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Employee</th>
                            <th>Department</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var u in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@u.EmpCd</strong><br />
                                        <small class="vni-font" style="text-transform: uppercase;">@u.FullName</small>
                                    </td>
                                    <td>
                                        @u.DeptCd<br />
                                        <small class="text-muted">Line: @u.LineCd</small><br />
                                        <small class="text-muted">Work: @u.WorkCd</small>
                                    </td>
                                    <td>@u.RoleName</td>
                                    <td>
                                        @if (u.IsActive == 1)
                                        {
                                            <span class="badge rounded-pill bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @* Dùng await Html.PartialAsync thay Html.Partial cũ *@
                                        @if (u.IsActive == 1)
                                        {
                                            @await Html.PartialAsync("_ConfirmButton", new ConfirmButtonModel
                                            {
                                                Url = Url.Action("DisableUser", new { empCd = u.EmpCd }) ?? "",
                                                Text = "Disable",
                                                ButtonClass = "btn btn-sm btn-danger",
                                                ConfirmMessage = "Khoá user này?"
                                            })
                                        }
                                        else
                                        {
                                            @await Html.PartialAsync("_ConfirmButton", new ConfirmButtonModel
                                            {
                                                Url = Url.Action("EnableUser", new { empCd = u.EmpCd }) ?? "",
                                                Text = "Enable",
                                                ButtonClass = "btn btn-sm btn-success",
                                                ConfirmMessage = "Mở khoá user này?"
                                            })
                                        }
                                        @await Html.PartialAsync("_ConfirmButton", new ConfirmButtonModel
                                        {
                                            Url = Url.Action("ResetPassword", new { empCd = u.EmpCd }) ?? "",
                                            Text = "Reset",
                                            ButtonClass = "btn btn-sm btn-warning",
                                            ConfirmMessage = "Reset password?"
                                        })
                                        <button type="button" class="btn btn-sm btn-info ms-1"
                                                onclick="openEditRoleModal('@u.EmpCd', '@u.FullName', @(u.RoleId ?? 0))">
                                            <i class="fas fa-user-tag"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center py-3">No data</td></tr>
                        }
                    </tbody>
                </table>

                <div class="d-flex justify-content-between align-items-center mt-3 px-4 pb-3">
                    <div class="text-sm text-secondary">
                        Trang <strong>@Model?.PageNumber</strong> / @Model?.PageCount
                    </div>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                        @if (Model != null && Model.PageCount > 1)
                        {
                            int totalPages = Model.PageCount;
                            int curPage   = Model.PageNumber;
                            int from      = Math.Max(1, curPage - 2);
                            int to        = Math.Min(totalPages, from + 4);
                            if (to - from < 4) from = Math.Max(1, to - 4);

                            string PUrl(int p) => Url.Action("UserManager", new {
                                page = p, deptCd = ViewBag.DeptCd, lineCd = ViewBag.LineCd,
                                workCd = ViewBag.WorkCd, roleId = ViewBag.RoleId,
                                empCd = ViewBag.EmpCd, pageSize = ViewBag.PageSize })!;

                            <li class="page-item @(curPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@PUrl(1)">&laquo;</a>
                            </li>
                            <li class="page-item @(curPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@PUrl(Math.Max(1, curPage - 1))">&lsaquo;</a>
                            </li>
                            if (from > 1)
                            {
                                <li class="page-item disabled"><a class="page-link">…</a></li>
                            }
                            for (int p = from; p <= to; p++)
                            {
                                <li class="page-item @(p == curPage ? "active" : "")">
                                    <a class="page-link" href="@PUrl(p)">@p</a>
                                </li>
                            }
                            if (to < totalPages)
                            {
                                <li class="page-item disabled"><a class="page-link">…</a></li>
                            }
                            <li class="page-item @(curPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="@PUrl(Math.Min(totalPages, curPage + 1))">&rsaquo;</a>
                            </li>
                            <li class="page-item @(curPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="@PUrl(totalPages)">&raquo;</a>
                            </li>
                        }
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Tạo User -->
<div class="modal fade" id="createUserModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="@Url.Action("CreateUser", "User")">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Create User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label>Emp Code</label>
                        <input name="EmpCd" class="form-control" required />
                    </div>
                    <div class="mb-2">
                        <label>Full Name</label>
                        <input name="FullName" class="form-control" required />
                    </div>
                    <div class="mb-2 mt-4">
                        <div class="input-group input-group-static">
                            <label class="text-primary fw-bold">Mật khẩu khởi tạo</label>
                            <input name="Password" type="text" value="123456" class="form-control text-danger fw-bold border-bottom" readonly />
                        </div>
                        <small class="text-muted" style="font-size: 0.75rem;">
                            <i class="fas fa-info-circle text-warning"></i> *Hệ thống sẽ ép buộc tự đổi ở lần đăng nhập đầu tiên.
                        </small>
                    </div>
                    <div class="mb-2">
                        <label>Role</label>
                        <select name="RoleId" class="select2 form-select" required
                                data-url="@Url.Action("GetRole", "Dropdown")">
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Đổi Role -->
<div class="modal fade" id="editRoleModal">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <form method="post" action="@Url.Action("UpdateRole", "User")">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editRoleEmpCd" name="empCd" />
                <div class="modal-header">
                    <h6 class="modal-title">Đổi Role &mdash; <span id="editRoleEmpName" class="text-primary"></span></h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label text-xs fw-bold text-uppercase text-secondary mb-1">Role mới</label>
                    <select id="editRoleSelect" name="roleId" class="form-select" required></select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary btn-sm">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            Select2Helper.init();
            $('#clearFilter').click(function () {
                $('#filterForm')[0].reset();
                $('.select2').val(null).trigger('change');
            });
            // Style pagination links
            $('.pagination li.page-item > a').addClass('page-link border-0 text-sm');
            $('.pagination li.page-item > span').addClass('page-link border-0 text-sm');

            // Reopen modal if server-side action set TempData["OpenModal"]
            @if (TempData["OpenModal"] != null)
            {
                <text>new bootstrap.Modal(document.getElementById('@TempData["OpenModal"]')).show();</text>
            }
        });

        function openEditRoleModal(empCd, fullName, currentRoleId) {
            document.getElementById('editRoleEmpCd').value = empCd;
            document.getElementById('editRoleEmpName').textContent = fullName;

            var $select = document.getElementById('editRoleSelect');
            $select.innerHTML = '<option value="">Đang tải...</option>';

            fetch('@Url.Action("GetRoleNoAdmin", "Dropdown")')
                .then(r => r.json())
                .then(data => {
                    $select.innerHTML = '';
                    data.forEach(function (role) {
                        var opt = new Option(role.text, role.id);
                        if (role.id == currentRoleId) opt.selected = true;
                        $select.appendChild(opt);
                    });
                });

            new bootstrap.Modal(document.getElementById('editRoleModal')).show();
        }
    </script>
}
